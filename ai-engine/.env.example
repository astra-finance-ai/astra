# AI Engine Environment Variables

# Server
NODE_ENV=development
PORT=4000
BACKEND_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/astra-ai

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# AI
GEMINI_API_KEY=your_gemini_api_key
NEWS_API_KEY=your_newsapi_key

# Caching TTL
AI_SCORE_TTL_HOURS=24
MARKET_SUMMARY_TTL_HOURS=6
WORLD_BANK_CACHE_DAYS=7

# Queue
SCORE_QUEUE_CONCURRENCY=3

# Chat
MAX_CHAT_HISTORY_MESSAGES=50

# Mock mode for development (set to true to use mock responses)
USE_MOCK_AI=false

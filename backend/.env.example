# Server
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://localhost:27017/astra
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your_jwt_secret_min_64_chars_change_this_in_production
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d
ADMIN_JWT_SECRET=your_admin_jwt_secret_min_64_chars_change_this_in_production
ADMIN_JWT_EXPIRY=8h

# Email
SENDGRID_API_KEY=your_sendgrid_key
EMAIL_FROM=noreply@astra.finance
EMAIL_FROM_NAME=Astra

# Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_key

# AI (Layer 2)
GEMINI_API_KEY=your_gemini_key
NEWS_API_KEY=your_newsapi_key

# Blockchain (Layer 3)
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
ASTRA_REGISTRY_PROGRAM_ID=
ASTRA_POOL_PROGRAM_ID=
ASTRA_YIELD_PROGRAM_ID=
SQUADS_MULTISIG_ADDRESS=
PLATFORM_SIGNER_1_KEYPAIR=
PLATFORM_SIGNER_2_KEYPAIR=
SWITCHBOARD_SOL_USD_FEED=
